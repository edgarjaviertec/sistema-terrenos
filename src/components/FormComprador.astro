---
const { modo = 'nuevo' } = Astro.props;
const titulo = modo === 'editar' ? 'Editar comprador' : 'Nuevo comprador';
---
<div class="contenedor-medio" x-data="formComprador">

  <div class="encabezado-pagina">
    <h1>{titulo}</h1>
  </div>
  <hr />

  <div class="alerta" data-tipo="error" x-show="error" x-text="error" x-cloak style="margin-bottom:1rem"></div>

  <div class="vacio" x-show="cargando && esEditar">Cargando comprador...</div>

  <form class="pila" @submit.prevent="guardar" x-show="!(cargando && esEditar)">
    <div class="tarjeta">
      <div class="pila">
        <div class="grupo-campo">
          <label>Nombre</label>
          <input type="text" x-model="form.nombre" required />
        </div>
        <div class="grupo-campo">
          <label>Teléfono</label>
          <input
            type="tel"
            inputmode="numeric"
            placeholder="9981234567"
            maxlength="10"
            x-model="form.telefono"
            @keydown="if (!$event.ctrlKey && !$event.metaKey && $event.key.length === 1 && !/[0-9]/.test($event.key)) $event.preventDefault()"
            @paste.prevent="form.telefono = $event.clipboardData.getData('text').replace(/\D/g, '').slice(0, 10)"
          />
        </div>
        <div class="grupo-campo">
          <label>Dirección</label>
          <input type="text" x-model="form.direccion" placeholder="Calle, colonia, ciudad" />
        </div>
      </div>
    </div>

    <div class="fila" style="justify-content: flex-end; gap: 0.75rem;">
      <a href="/compradores" class="boton">Cancelar</a>
      <button class="boton" data-tipo="primario" type="submit" :disabled="cargando">
        <span x-text="cargando ? 'Guardando...' : 'Guardar'"></span>
      </button>
    </div>
  </form>

</div>
