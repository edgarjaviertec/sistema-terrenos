---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Recibo — Sistema de Terrenos" chrome={false}>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <style is:global>
        /* ── Layout base ── */
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }

        .layout { display: flex; height: 100vh; }

        /* ── Área del machote ── */
        .machote-area {
            flex: 1;
            overflow: auto;
            background: var(--gris-fondo);
            padding: 1.5rem;
            display: flex;
            align-items: flex-start;
            justify-content: flex-start;
        }

        /* ── Machote ── */
        @page { size: Letter landscape; margin: 0; }

        @media print {
            html, body { height: auto; overflow: visible; }
            .sidebar, .sidebar-tab { display: none !important; }
            .layout { display: block; }
            .machote-area { padding: 0; background: white; }
            html, body { margin: 0 !important; padding: 0 !important; background: white !important; }
            * { visibility: hidden; }
            .pagina, .pagina * { visibility: visible; }
            .pagina {
                position: fixed !important;
                top: 0 !important; left: 0 !important;
                margin: 0 !important; padding: 0 !important;
                box-shadow: none !important; border: none !important;
                width: 27.94cm !important; height: 21.59cm !important;
            }
        }

        .pagina {
            display: flex;
            flex-direction: row;
            width: 27.94cm;
            height: 21.59cm;
            overflow: hidden;
            background: white;
            flex-shrink: 0;
        }

        .formato { position: relative; padding: 0.6cm; width: 13.97cm; height: 21.59cm; overflow: hidden; }
        .formato:first-child { border-right: 0.5pt dashed #000; }
        .formato:last-child  { border-left: 0.5pt dashed #000; }

        .formato.copia::after {
            content: "COPIA";
            pointer-events: none;
            opacity: 0.15;
            font-size: 3cm;
            font-weight: 700;
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%) rotate(45deg);
            color: black;
        }

        .m-encabezado {
            display: grid;
            grid-template-columns: 1fr auto;
            align-items: baseline;
            margin-bottom: 0.4cm;
            font-family: Arial, Helvetica, sans-serif;
        }

        .m-titulo { text-align: center; font-weight: 700; font-size: 11pt; letter-spacing: 0.03em; }
        .m-folio { font-weight: 700; font-size: 11pt; white-space: nowrap; }
        .m-folio .num { color: #c00; font-weight: 700; font-size: 14pt; }

        .m-bloque {
            border: 1pt solid #000;
            padding: 0.25cm;
            margin-bottom: 0.4cm;
            border-radius: 5pt;
            box-shadow: 3pt 3pt #000;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 10pt;
        }

        .m-fila { margin-bottom: 0.12cm; }
        .m-etq { font-weight: 700; display: inline; }
        .m-val { display: inline; text-transform: uppercase; }

        .m-pagos { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; margin-bottom: 0.2cm; }
        .m-pagos .m-fila { margin-bottom: 0.15cm; }

        .m-nota {
            text-align: center;
            font-weight: 700;
            font-size: 10pt;
            font-family: Arial, Helvetica, sans-serif;
            margin: 0.3cm 0 0.2cm;
        }

        .m-clausulas { font-size: 9pt; font-family: Arial, Helvetica, sans-serif; }
        .m-clausulas ol { margin: 0; padding-left: 0.5cm; }
        .m-clausulas li { margin-bottom: 0.15cm; }

        .m-firmas {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1cm;
            margin-top: 0.8cm;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 10pt;
        }

        .m-firma { text-align: center; padding-top: 0.25cm; border-top: 1pt solid #000; }

        /* ── Sidebar ── */
        .sidebar {
            width: 400px;
            flex-shrink: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            border-left: 1px solid var(--borde);
            background: var(--blanco);
            transition: width 0.2s ease;
            overflow: hidden;
        }

        .sidebar[data-cerrado] { width: 0; border-left: none; }

        .sidebar-header {
            padding: 1rem;
            border-bottom: 1px solid var(--borde);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
        }

        .sidebar-cerrar {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.3rem;
            color: var(--negro);
            padding: 0.25rem;
            line-height: 1;
        }

        .sidebar-body {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .sidebar-body input,
        .sidebar-body select { text-transform: uppercase; }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid var(--borde);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sidebar-footer .fila-botones { display: flex; gap: 0.5rem; }
        .sidebar-footer .fila-botones .boton { flex: 1; text-align: center; }

        /* ── Toggle del sidebar ── */
        .sidebar-tab {
            position: fixed;
            top: 50%;
            right: 0;
            transform: translateY(-50%);
            width: 28px;
            height: 64px;
            background: var(--negro);
            border: none;
            border-radius: 8px 0 0 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 20;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--blanco);
            transition: right 0.2s ease;
        }

        .sidebar-tab--abierto { right: 400px; }

        /* ── Campos del sidebar ── */
        .seccion-titulo {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #555;
            margin-bottom: 0.25rem;
        }

        .alerta-sidebar {
            font-size: 0.8rem;
            padding: 0.5rem 0.75rem;
            border-radius: var(--radio);
            border: 1px solid;
        }
        .alerta-sidebar[data-tipo="error"] { background: #fff0f0; border-color: #fcc; color: #900; }
        .alerta-sidebar[data-tipo="exito"] { background: #f0fff4; border-color: #9f9; color: #060; }

        /* ── Mobile < 576px ── */
        @media (max-width: 575.98px) {
            .machote-area { padding: 0; }
            .sidebar { width: 100%; }
            .sidebar-tab--abierto { right: 100%; }
            .sidebar-footer .fila-botones { flex-direction: column; }
            .sidebar-cerrar { display: flex; }
        }
    </style>
  </Fragment>

  <div class="layout" x-data="editarRecibo">

    <!-- ══ ÁREA DEL MACHOTE ══ -->
    <div class="machote-area">
      <div class="vacio" x-show="cargando" style="margin:auto;">Cargando recibo...</div>

      <div class="pagina" id="machote" x-show="!cargando">
        <!-- ORIGINAL -->
        <section class="formato">
          <div class="m-encabezado">
            <div class="m-titulo">CONTRATO DE COMPRAVENTA</div>
            <div class="m-folio">No. <span class="num" x-text="folioFormateado"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL COMPRADOR:</span> <span class="m-val" x-text="r.comprador_nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="r.comprador_telefono || '—'"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="r.comprador_direccion || '—'"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL VENDEDOR:</span> <span class="m-val" x-text="vendedor.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="vendedor.telefono"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="vendedor.direccion"></span></div>
          </div>
          <div class="m-pagos">
            <div class="m-fila"><span class="m-etq">RECIBÍ DE:</span> <span class="m-val" x-text="form.recibiDe || r.comprador_nombre"></span></div>
            <div class="m-fila"><span class="m-etq">LA CANTIDAD DE:</span> <span class="m-val" x-text="formatearMonto(form.cantidad)"></span></div>
            <div class="m-fila"><span class="m-etq">SON:</span> <span class="m-val" x-text="cantidadEnLetras"></span></div>
            <div class="m-fila"><span class="m-etq">POR CONCEPTO DE:</span> <span class="m-val" x-text="form.concepto"></span></div>
            <div class="m-fila"><span class="m-etq">FECHA:</span> <span class="m-val" x-text="fechaFormateada"></span></div>
          </div>
          <div class="m-nota">
            EL COSTO TOTAL DEL TERRENO ES DE <strong x-text="formatearMonto(r.costo_total)"></strong> M.N.
          </div>
          <div class="m-clausulas">
            <ol>
              <li>El vendedor se compromete con los términos legales de este terreno, siempre y cuando el comprador cumpla puntualmente con los pagos fijados en este contrato.</li>
              <li>El comprador se compromete a hacer los pagos puntualmente los días <strong x-text="r.dia_pago || '—'"></strong> de cada mes correspondiente y la cantidad mínima es de <strong x-text="formatearMonto(r.abono_minimo)"></strong>, salvo si el comprador desea pagar mayor cantidad, será aceptado por el vendedor para liquidar más rápido su terreno.</li>
              <li>Una vez firmado el contrato de compraventa, no hay devolución de enganche, salvo que el comprador busque otro comprador del terreno para hacer el traspaso correspondiente a nombre del nuevo comprador.</li>
              <li>Cabe mencionar que estos terrenos son rurales; por el momento no cuentan con servicios de luz y agua, hasta que se extienda la población.</li>
            </ol>
          </div>
          <div class="m-firmas">
            <div class="m-firma">FIRMA DEL VENDEDOR</div>
            <div class="m-firma">FIRMA DEL COMPRADOR</div>
          </div>
        </section>

        <!-- COPIA -->
        <section class="formato copia">
          <div class="m-encabezado">
            <div class="m-titulo">CONTRATO DE COMPRAVENTA</div>
            <div class="m-folio">No. <span class="num" x-text="folioFormateado"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL COMPRADOR:</span> <span class="m-val" x-text="r.comprador_nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="r.comprador_telefono || '—'"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="r.comprador_direccion || '—'"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL VENDEDOR:</span> <span class="m-val" x-text="vendedor.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="vendedor.telefono"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="vendedor.direccion"></span></div>
          </div>
          <div class="m-pagos">
            <div class="m-fila"><span class="m-etq">RECIBÍ DE:</span> <span class="m-val" x-text="form.recibiDe || r.comprador_nombre"></span></div>
            <div class="m-fila"><span class="m-etq">LA CANTIDAD DE:</span> <span class="m-val" x-text="formatearMonto(form.cantidad)"></span></div>
            <div class="m-fila"><span class="m-etq">SON:</span> <span class="m-val" x-text="cantidadEnLetras"></span></div>
            <div class="m-fila"><span class="m-etq">POR CONCEPTO DE:</span> <span class="m-val" x-text="form.concepto"></span></div>
            <div class="m-fila"><span class="m-etq">FECHA:</span> <span class="m-val" x-text="fechaFormateada"></span></div>
          </div>
          <div class="m-nota">
            EL COSTO TOTAL DEL TERRENO ES DE <strong x-text="formatearMonto(r.costo_total)"></strong> M.N.
          </div>
          <div class="m-clausulas">
            <ol>
              <li>El vendedor se compromete con los términos legales de este terreno, siempre y cuando el comprador cumpla puntualmente con los pagos fijados en este contrato.</li>
              <li>El comprador se compromete a hacer los pagos puntualmente los días <strong x-text="r.dia_pago || '—'"></strong> de cada mes correspondiente y la cantidad mínima es de <strong x-text="formatearMonto(r.abono_minimo)"></strong>, salvo si el comprador desea pagar mayor cantidad, será aceptado por el vendedor para liquidar más rápido su terreno.</li>
              <li>Una vez firmado el contrato de compraventa, no hay devolución de enganche, salvo que el comprador busque otro comprador del terreno para hacer el traspaso correspondiente a nombre del nuevo comprador.</li>
              <li>Cabe mencionar que estos terrenos son rurales; por el momento no cuentan con servicios de luz y agua, hasta que se extienda la población.</li>
            </ol>
          </div>
          <div class="m-firmas">
            <div class="m-firma">FIRMA DEL VENDEDOR</div>
            <div class="m-firma">FIRMA DEL COMPRADOR</div>
          </div>
        </section>
      </div>
    </div>

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" :data-cerrado="!sidebarAbierto || undefined">

      <div class="sidebar-header">
        <div class="sidebar-header-texto">
          <div class="titulo-seccion" x-text="esDuplicar ? 'DUPLICAR RECIBO' : 'EDITAR RECIBO'"></div>
        </div>
        <button type="button" class="sidebar-cerrar" @click="sidebarAbierto = false" aria-label="Cerrar">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="sidebar-body">
        <div class="alerta-sidebar" data-tipo="error" x-show="error" x-text="error"></div>
        <div class="alerta-sidebar" data-tipo="exito" x-show="exito" x-text="exito"></div>

        <form class="pila" style="gap:0.75rem;" @submit.prevent="guardar" id="form-editar">
          <div class="grupo-campo">
            <label>Fecha de pago</label>
            <input type="text" x-ref="fechaEditar" required />
          </div>
          <div class="grupo-campo">
            <label>Recibí de</label>
            <input type="text" x-model="form.recibiDe" />
          </div>
          <div class="grupo-campo">
            <label>Cantidad</label>
            <input type="number" step="0.01" x-model="form.cantidad" required />
          </div>
          <div class="grupo-campo">
            <label>Concepto</label>
            <input type="text" x-model="form.concepto" />
          </div>
        </form>
      </div>

      <div class="sidebar-footer">
        <button class="boton" @click="imprimir"><i class="fa-solid fa-print"></i> Imprimir</button>
        <button class="boton" @click="guardarPDF"><i class="fa-solid fa-file-pdf"></i> Descargar PDF</button>
        <div class="fila-botones">
          <a href="/" class="boton" style="text-align:center;"><i class="fa-solid fa-x"></i> Cancelar</a>
          <button type="submit" form="form-editar" class="boton" data-tipo="primario" :disabled="cargando">
            <i class="fa-solid fa-check"></i> <span x-text="cargando ? 'Guardando...' : 'Guardar'"></span>
          </button>
        </div>
      </div>

    </aside>

    <!-- Tab siempre visible que se mueve con el sidebar -->
    <button class="sidebar-tab" @click="sidebarAbierto = !sidebarAbierto" :class="{ 'sidebar-tab--abierto': sidebarAbierto }">
      <i class="fa-solid" :class="sidebarAbierto ? 'fa-angle-right' : 'fa-angle-left'"></i>
    </button>

  </div>

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/html2pdf.js@0.10.1/dist/html2pdf.bundle.min.js"></script>
    <script is:inline src="/js/editar.js"></script>
  </Fragment>
</Layout>
