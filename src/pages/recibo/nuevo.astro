---
import Layout from '../../layouts/Layout.astro';
import InputTelefono from '../../components/InputTelefono.astro';
---
<Layout title="Nuevo Recibo — Sistema de Terrenos" chrome={false}>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2/dist/css/tom-select.min.css" />
    <link rel="stylesheet" href="/css/machote.css" />
    <style is:global>
      .campo-nuevo {
        background: #fffbe6;
        border: 2px dashed var(--negro);
        border-radius: var(--radio);
        padding: 0.75rem;
      }
      /* Tom Select acorde al estilo */
      .ts-wrapper .ts-control {
        border: var(--borde);
        border-radius: var(--radio);
        padding: 0.5rem 0.75rem;
        min-height: auto;
        box-shadow: none;
      }
      /* Evita el salto de altura: resetea márgenes/padding de los hijos */
      .ts-wrapper .ts-control > input,
      .ts-wrapper .ts-control > .item {
        margin: 0;
        padding: 0;
        line-height: 1.5;
      }
      /* Tom Select fija un width inline al input que provoca wrap; lo forzamos */
      .ts-wrapper .ts-control > input {
        width: auto !important;
      }
      .ts-wrapper.focus .ts-control { box-shadow: none; border-color: var(--negro); }
      .ts-dropdown { border: var(--borde); border-radius: var(--radio); margin-top: 2px; }
    </style>
  </Fragment>

  <div class="layout" x-data="nuevoRecibo">

    <!-- ══ ÁREA DEL MACHOTE ══ -->
    <div class="machote-area">
      <div class="vacio" x-show="!listoParaPreview" style="margin:auto; max-width:320px;">
        <i class="fa-solid fa-file-invoice-dollar fa-4x vacio__icono"></i>
        <p>Selecciona un comprador y un terreno para ver el recibo.</p>
      </div>

      <div class="pagina" id="machote" x-show="listoParaPreview" x-cloak>
        <!-- ORIGINAL -->
        <section class="formato">
          <div class="m-encabezado">
            <div class="m-titulo">CONTRATO DE COMPRAVENTA</div>
            <div class="m-folio">No. <span class="num" x-text="folioFormateado"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL COMPRADOR:</span> <span class="m-val" x-text="comprador.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="comprador.telefono || '—'"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="comprador.direccion || '—'"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL VENDEDOR:</span> <span class="m-val" x-text="vendedor.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="vendedor.telefono"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="vendedor.direccion"></span></div>
          </div>
          <div class="m-pagos">
            <div class="m-fila"><span class="m-etq">RECIBÍ DE:</span> <span class="m-val" x-text="form.recibiDe || comprador.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">LA CANTIDAD DE:</span> <span class="m-val" x-text="formatearMonto(form.cantidad)"></span></div>
            <div class="m-fila"><span class="m-etq">SON:</span> <span class="m-val" x-text="cantidadEnLetras"></span></div>
            <div class="m-fila"><span class="m-etq">POR CONCEPTO DE:</span> <span class="m-val" x-text="form.concepto"></span></div>
            <div class="m-fila"><span class="m-etq">FECHA:</span> <span class="m-val" x-text="fechaFormateada"></span></div>
          </div>
          <div class="m-nota">
            EL COSTO TOTAL DEL TERRENO ES DE <strong x-text="formatearMonto(terreno.costo_total)"></strong> M.N.
          </div>
          <div class="m-clausulas">
            <ol>
              <li>El vendedor se compromete con los términos legales de este terreno, siempre y cuando el comprador cumpla puntualmente con los pagos fijados en este contrato.</li>
              <li>El comprador se compromete a hacer los pagos puntualmente los días <strong x-text="terreno.dia_pago || '—'"></strong> de cada mes correspondiente y la cantidad mínima es de <strong x-text="formatearMonto(terreno.abono_minimo)"></strong>, salvo si el comprador desea pagar mayor cantidad, será aceptado por el vendedor para liquidar más rápido su terreno.</li>
              <li>Una vez firmado el contrato de compraventa, no hay devolución de enganche, salvo que el comprador busque otro comprador del terreno para hacer el traspaso correspondiente a nombre del nuevo comprador.</li>
              <li>Cabe mencionar que estos terrenos son rurales; por el momento no cuentan con servicios de luz y agua, hasta que se extienda la población.</li>
            </ol>
          </div>
          <div class="m-firmas">
            <div class="m-firma">FIRMA DEL VENDEDOR</div>
            <div class="m-firma">FIRMA DEL COMPRADOR</div>
          </div>
        </section>

        <!-- COPIA -->
        <section class="formato copia">
          <div class="m-encabezado">
            <div class="m-titulo">CONTRATO DE COMPRAVENTA</div>
            <div class="m-folio">No. <span class="num" x-text="folioFormateado"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL COMPRADOR:</span> <span class="m-val" x-text="comprador.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="comprador.telefono || '—'"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="comprador.direccion || '—'"></span></div>
          </div>
          <div class="m-bloque">
            <div class="m-fila"><span class="m-etq">NOMBRE DEL VENDEDOR:</span> <span class="m-val" x-text="vendedor.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">TELÉFONO:</span> <span class="m-val" x-text="vendedor.telefono"></span></div>
            <div class="m-fila"><span class="m-etq">DIRECCIÓN:</span> <span class="m-val" x-text="vendedor.direccion"></span></div>
          </div>
          <div class="m-pagos">
            <div class="m-fila"><span class="m-etq">RECIBÍ DE:</span> <span class="m-val" x-text="form.recibiDe || comprador.nombre"></span></div>
            <div class="m-fila"><span class="m-etq">LA CANTIDAD DE:</span> <span class="m-val" x-text="formatearMonto(form.cantidad)"></span></div>
            <div class="m-fila"><span class="m-etq">SON:</span> <span class="m-val" x-text="cantidadEnLetras"></span></div>
            <div class="m-fila"><span class="m-etq">POR CONCEPTO DE:</span> <span class="m-val" x-text="form.concepto"></span></div>
            <div class="m-fila"><span class="m-etq">FECHA:</span> <span class="m-val" x-text="fechaFormateada"></span></div>
          </div>
          <div class="m-nota">
            EL COSTO TOTAL DEL TERRENO ES DE <strong x-text="formatearMonto(terreno.costo_total)"></strong> M.N.
          </div>
          <div class="m-clausulas">
            <ol>
              <li>El vendedor se compromete con los términos legales de este terreno, siempre y cuando el comprador cumpla puntualmente con los pagos fijados en este contrato.</li>
              <li>El comprador se compromete a hacer los pagos puntualmente los días <strong x-text="terreno.dia_pago || '—'"></strong> de cada mes correspondiente y la cantidad mínima es de <strong x-text="formatearMonto(terreno.abono_minimo)"></strong>, salvo si el comprador desea pagar mayor cantidad, será aceptado por el vendedor para liquidar más rápido su terreno.</li>
              <li>Una vez firmado el contrato de compraventa, no hay devolución de enganche, salvo que el comprador busque otro comprador del terreno para hacer el traspaso correspondiente a nombre del nuevo comprador.</li>
              <li>Cabe mencionar que estos terrenos son rurales; por el momento no cuentan con servicios de luz y agua, hasta que se extienda la población.</li>
            </ol>
          </div>
          <div class="m-firmas">
            <div class="m-firma">FIRMA DEL VENDEDOR</div>
            <div class="m-firma">FIRMA DEL COMPRADOR</div>
          </div>
        </section>
      </div>
    </div>

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" :data-cerrado="!sidebarAbierto || undefined">

      <div class="sidebar-header">
        <div class="titulo-seccion">NUEVO RECIBO</div>
        <button type="button" class="sidebar-cerrar" @click="sidebarAbierto = false" aria-label="Cerrar">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="sidebar-body">
        <div class="alerta-sidebar" data-tipo="error" x-show="error" x-text="error"></div>

        <form @submit.prevent="guardar" id="form-nuevo" class="pila" style="gap:0.75rem;">

          <p class="seccion-titulo">Comprador</p>
          <div class="grupo-campo">
            <label>Comprador</label>
            <select x-ref="selComprador"></select>
          </div>
          <div class="campo-nuevo pila" x-show="esCompradorNuevo" x-cloak style="gap:0.5rem;">
            <div class="grupo-campo">
              <label>Nombre</label>
              <input type="text" x-model="comprador.nombre" />
            </div>
            <div class="grupo-campo">
              <label>Teléfono</label>
              <InputTelefono modelo="comprador.telefono" />
            </div>
            <div class="grupo-campo">
              <label>Dirección</label>
              <input type="text" x-model="comprador.direccion" />
            </div>
          </div>

          <p class="seccion-titulo">Terreno</p>
          <div class="grupo-campo">
            <label>Terreno</label>
            <select x-ref="selTerreno"></select>
          </div>
          <div class="campo-nuevo pila" x-show="esTerrenoNuevo" x-cloak style="gap:0.5rem;">
            <div class="grupo-campo">
              <label>Descripción</label>
              <textarea x-model="terreno.descripcion" rows="2"></textarea>
            </div>
            <div class="fila">
              <div class="grupo-campo">
                <label>Costo total</label>
                <input type="number" step="0.01" x-model="terreno.costo_total" />
              </div>
              <div class="grupo-campo">
                <label>Abono mínimo</label>
                <input type="number" step="0.01" x-model="terreno.abono_minimo" />
              </div>
            </div>
            <div class="grupo-campo">
              <label>Día de pago</label>
              <input type="number" min="1" max="31" x-model="terreno.dia_pago" />
            </div>
          </div>

          <p class="seccion-titulo">Datos del pago</p>
          <div class="grupo-campo">
            <label>Fecha de pago</label>
            <input type="text" x-ref="fechaNuevo" />
          </div>
          <div class="grupo-campo">
            <label>Recibí de</label>
            <input type="text" x-model="form.recibiDe" />
          </div>
          <div class="grupo-campo">
            <label>Cantidad</label>
            <input type="number" step="0.01" x-model="form.cantidad" />
          </div>
          <div class="grupo-campo">
            <label>Concepto</label>
            <input type="text" x-model="form.concepto" />
          </div>
        </form>
      </div>

      <div class="sidebar-footer">
        <button class="boton" @click="imprimir"><i class="fa-solid fa-print"></i> Imprimir</button>
        <div class="fila-botones">
          <a href="/" class="boton" style="text-align:center;"><i class="fa-solid fa-x"></i> Cancelar</a>
          <button type="submit" form="form-nuevo" class="boton" data-tipo="primario" :disabled="cargando">
            <i class="fa-solid fa-check"></i> <span x-text="cargando ? 'Guardando...' : 'Guardar'"></span>
          </button>
        </div>
      </div>

    </aside>

    <button class="sidebar-tab" @click="sidebarAbierto = !sidebarAbierto" :class="{ 'sidebar-tab--abierto': sidebarAbierto }">
      <i class="fa-solid" :class="sidebarAbierto ? 'fa-angle-right' : 'fa-angle-left'"></i>
    </button>

  </div>

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/tom-select@2/dist/js/tom-select.complete.min.js"></script>
    <script is:inline src="/js/nuevo-recibo.js"></script>
  </Fragment>
</Layout>
