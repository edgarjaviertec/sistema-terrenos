---
import Layout from '../../layouts/Layout.astro';
import FormTerreno from '../../components/FormTerreno.astro';
---
<Layout title="Nuevo Terreno — Mis Terrenos">
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2/dist/css/tom-select.min.css" />
  </Fragment>

  <FormTerreno modo="nuevo" />

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.jsdelivr.net/npm/tom-select@2/dist/js/tom-select.complete.min.js"></script>
    <script is:inline src="/js/terreno-form.js"></script>
  </Fragment>
</Layout>
